FROM alpine:3.22.2

ARG ENVIRONNEMENT
ENV ENVIRONNEMENT=${ENVIRONNEMENT}

RUN apk add --no-cache \
    coreutils \
    gettext \
    php82-fpm \
    php82-ctype \
    php82-curl \
    php82-dom \
    php82-gd \
    php82-iconv \
    php82-json \
    php82-intl \
    php82-fileinfo \
    php82-mbstring \
    php82-opcache \
    php82-openssl \
    php82-pdo \
    php82-pdo_pgsql \
    php82-pdo_sqlite \
    php82-sqlite3 \
    php82-xml \
    php82-xsl \
    php82-zlib \
    php82-phar \
    php82-tokenizer \
    php82-session \
    php82-simplexml \
    php82-zip \
    php82-xmlreader \
    php82-xmlwriter \
    php82-sodium \
    php82-pecl-apcu \
    php82-sockets \
    make \
    curl \
    sudo \
    bash \
    openssl

COPY $ENVIRONNEMENT/php-fpm/php.ini /etc/php82/php.ini
COPY $ENVIRONNEMENT/php-fpm/php-fpm.conf /etc/php82/php-fpm.conf
COPY $ENVIRONNEMENT/php-fpm/www.conf /etc/php82/php-fpm.d/www.conf

RUN curl -sS https://getcomposer.org/installer | tee composer-setup.php \
    && php82 composer-setup.php && rm composer-setup.php* \
    && chmod +x composer.phar && mv composer.phar /usr/bin/composer \
    && ln -s /usr/bin/php82 /usr/local/bin/php

RUN apk add --update nodejs npm \
    && npm install --global yarn \
    && chown -R nobody:nobody /usr/local/lib/node_modules/

RUN mkdir -p /var/www/symfony/
RUN chown -R nobody:nobody /var/www/symfony/
RUN chown -R nobody:nobody /var/log/php82

WORKDIR /var/www/symfony

CMD ["php-fpm82", "-F"]
EXPOSE 9001
